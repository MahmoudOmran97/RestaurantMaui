<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary -->
    <Color x:Key="Primary">#FF5722</Color>
    <Color x:Key="PrimaryDark">#C62828</Color>
    <Color x:Key="PrimaryLight">#FF8A65</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#388E3C</Color>
    <Color x:Key="Warning">#F57C00</Color>
    <Color x:Key="Danger">#D32F2F</Color>
    <Color x:Key="Info">#0288D1</Color>

    <!-- Neutrals -->
    <Color x:Key="Background">#F5F5F5</Color>
    <Color x:Key="Surface">White</Color>
    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="Divider">#E0E0E0</Color>

</ResourceDictionary>
