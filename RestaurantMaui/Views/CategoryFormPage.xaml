<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RestaurantMaui.ViewModels"
             x:Class="RestaurantMaui.Views.CategoryFormPage"
             x:DataType="vm:CategoryFormViewModel"
             BackgroundColor="#F5F5F5"
             Title="{Binding PageTitle}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding CancelCommand}" IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16"
                             MaximumWidthRequest="500" HorizontalOptions="Center">

            <!-- زر رجوع يدوي (لان NavBar مخفي) -->
            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,4">
                <Button Grid.Column="0"
                        Text="&#x2190; رجوع"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#FF5722"
                        FontSize="15" Padding="0"
                        HorizontalOptions="Start" />
                <Label Grid.Column="1"
                       Text="{Binding PageTitle}"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="#212121"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Form Card -->
            <Frame CornerRadius="16" BackgroundColor="White"
                   HasShadow="True" BorderColor="Transparent" Padding="20">
                <VerticalStackLayout Spacing="16">

                    <!-- اسم القسم -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="اسم القسم *" FontSize="13" TextColor="#757575" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
                            <Entry Text="{Binding Name}"
                                   Placeholder="مثال: المقبلات، الوجبات الرئيسية، المشروبات"
                                   BackgroundColor="Transparent" Margin="8,2" FontSize="15" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- رابط الصورة -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="رابط صورة القسم (اختياري)" FontSize="13" TextColor="#757575" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
                            <Entry Text="{Binding ImageUrl}"
                                   Placeholder="https://..."
                                   BackgroundColor="Transparent" Margin="8,2" FontSize="13"
                                   Keyboard="Url" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- الترتيب (يظهر فقط في وضع التعديل) -->
                    <VerticalStackLayout Spacing="4"
                                         IsVisible="{Binding IsEdit}">
                        <Label Text="الترتيب في القائمة" FontSize="13" TextColor="#757575" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
                            <Entry Text="{Binding SortOrder}"
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent" Margin="8,2" FontSize="15" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Error Message -->
                    <Label Text="{Binding ErrorMsg}"
                           TextColor="#D32F2F" FontSize="13"
                           IsVisible="{Binding ErrorMsg, Converter={StaticResource StringToBoolConverter}}"
                           HorizontalOptions="Center" />

                </VerticalStackLayout>
            </Frame>

            <!-- Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0" Text="إلغاء"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="#9E9E9E" TextColor="White"
                        CornerRadius="12" HeightRequest="52" FontSize="16" />
                <Button Grid.Column="1"
                        Text="{Binding IsEdit, Converter={StaticResource BoolToStringConverter},
                               ConverterParameter='&#x1F4BE; حفظ التعديلات|&#x2795; إضافة القسم'}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        BackgroundColor="#FF5722" TextColor="White"
                        CornerRadius="12" HeightRequest="52" FontSize="16" FontAttributes="Bold" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#FF5722" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>