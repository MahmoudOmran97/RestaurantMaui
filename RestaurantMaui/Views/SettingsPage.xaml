<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RestaurantMaui.ViewModels"
             x:Class="RestaurantMaui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             BackgroundColor="#F5F5F5"
             Title="الإعدادات">

	<ScrollView>
		<VerticalStackLayout Padding="16" Spacing="16"
                             MaximumWidthRequest="700" HorizontalOptions="Center">

			<!-- User Card -->
			<Frame CornerRadius="16" BackgroundColor="#FF5722" HasShadow="True" BorderColor="Transparent" Padding="20">
				<Grid ColumnDefinitions="Auto,*,Auto">
					<Frame Grid.Column="0" WidthRequest="56" HeightRequest="56"
                           CornerRadius="28" BackgroundColor="White"
                           BorderColor="Transparent" Padding="0">
						<Label Text="👤" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
					</Frame>
					<VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center" Spacing="2">
						<Label Text="{Binding UserName}" FontSize="17" FontAttributes="Bold" TextColor="White" />
						<Label Text="{Binding UserEmail}" FontSize="12" TextColor="#FFCCBC" />
						<Label Text="{Binding UserRole}" FontSize="11" TextColor="#FFCCBC" />
					</VerticalStackLayout>
					<Button Grid.Column="2" Text="خروج 🚪"
                            Command="{Binding LogoutCommand}"
                            BackgroundColor="White" TextColor="#FF5722"
                            CornerRadius="10" HeightRequest="40" Padding="12,0"
                            VerticalOptions="Center" />
				</Grid>
			</Frame>

			<!-- Connection Settings -->
			<Frame CornerRadius="16" BackgroundColor="White" HasShadow="True" BorderColor="Transparent" Padding="20">
				<VerticalStackLayout Spacing="12">
					<Label Text="⚙️ إعدادات الاتصال" FontSize="16" FontAttributes="Bold" TextColor="#212121" />
					<BoxView HeightRequest="1" Color="#F0F0F0" />
					<VerticalStackLayout Spacing="4">
						<Label Text="رابط السيرفر (Base URL)" FontSize="13" TextColor="#757575" />
						<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
							<Entry Text="{Binding ApiUrl}" Placeholder="https://yourserver.com"
                                   BackgroundColor="Transparent" Margin="8,2" FontSize="13" Keyboard="Url" />
						</Border>
					</VerticalStackLayout>
					<Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
						<Label Grid.Column="0"
                               Text="{Binding ConnectionStatus}"
                               FontSize="13" VerticalOptions="Center"
                               TextColor="{Binding ConnectionStatus,
                                   Converter={StaticResource StatusTextColorConverter}}" />
						<Button Grid.Column="1" Text="اختبار الاتصال"
                                Command="{Binding TestConnectionCommand}"
                                BackgroundColor="#FF5722" TextColor="White"
                                CornerRadius="10" HeightRequest="44" Padding="16,0" />
					</Grid>
				</VerticalStackLayout>
			</Frame>

			<!-- Restaurant Info -->
			<Frame CornerRadius="16" BackgroundColor="White" HasShadow="True" BorderColor="Transparent" Padding="20">
				<VerticalStackLayout Spacing="12">
					<Grid ColumnDefinitions="*,Auto,Auto">
						<Label Grid.Column="0" Text="🍽️ بيانات المطعم"
                               FontSize="16" FontAttributes="Bold" TextColor="#212121"
                               VerticalOptions="Center" />
						<Button Grid.Column="1" Text="تحميل"
                                Command="{Binding LoadInfoCommand}"
                                BackgroundColor="#0288D1" TextColor="White"
                                CornerRadius="10" HeightRequest="38" Padding="12,0" Margin="4,0" />
						<Button Grid.Column="2" Text="💾 حفظ"
                                Command="{Binding SaveInfoCommand}"
                                BackgroundColor="#388E3C" TextColor="White"
                                CornerRadius="10" HeightRequest="38" Padding="12,0" />
					</Grid>
					<BoxView HeightRequest="1" Color="#F0F0F0" />

					<Label Text="{Binding InfoStatus}" FontSize="13"
                           TextColor="{Binding InfoStatus, Converter={StaticResource StatusTextColorConverter}}"
                           IsVisible="{Binding InfoStatus, Converter={StaticResource StringToBoolConverter}}" />

					<!-- اسم المطعم -->
					<Grid ColumnDefinitions="*,*" ColumnSpacing="12">
						<VerticalStackLayout Grid.Column="0" Spacing="4">
							<Label Text="اسم المطعم" FontSize="13" TextColor="#757575" />
							<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
								<Entry Text="{Binding RestName}" BackgroundColor="Transparent" Margin="8,2" FontSize="14" />
							</Border>
						</VerticalStackLayout>
						<VerticalStackLayout Grid.Column="1" Spacing="4">
							<Label Text="رقم الهاتف" FontSize="13" TextColor="#757575" />
							<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
								<Entry Text="{Binding RestPhone}" Keyboard="Telephone"
                                       BackgroundColor="Transparent" Margin="8,2" FontSize="14" />
							</Border>
						</VerticalStackLayout>
					</Grid>

					<!-- عنوان -->
					<VerticalStackLayout Spacing="4">
						<Label Text="العنوان" FontSize="13" TextColor="#757575" />
						<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
							<Entry Text="{Binding RestAddress}" BackgroundColor="Transparent" Margin="8,2" FontSize="14" />
						</Border>
					</VerticalStackLayout>

					<!-- وصف -->
					<VerticalStackLayout Spacing="4">
						<Label Text="الوصف" FontSize="13" TextColor="#757575" />
						<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
							<Editor Text="{Binding RestDesc}" BackgroundColor="Transparent"
                                    Margin="8,2" HeightRequest="70" FontSize="13" />
						</Border>
					</VerticalStackLayout>

					<!-- Fees + Time -->
					<Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
						<VerticalStackLayout Grid.Column="0" Spacing="4">
							<Label Text="رسوم التوصيل" FontSize="12" TextColor="#757575" />
							<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
								<Entry Text="{Binding DeliveryFee}" Keyboard="Numeric"
                                       BackgroundColor="Transparent" Margin="8,2" FontSize="14" />
							</Border>
						</VerticalStackLayout>
						<VerticalStackLayout Grid.Column="1" Spacing="4">
							<Label Text="الحد الأدنى للطلب" FontSize="12" TextColor="#757575" />
							<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
								<Entry Text="{Binding MinOrder}" Keyboard="Numeric"
                                       BackgroundColor="Transparent" Margin="8,2" FontSize="14" />
							</Border>
						</VerticalStackLayout>
						<VerticalStackLayout Grid.Column="2" Spacing="4">
							<Label Text="وقت التوصيل (دقيقة)" FontSize="12" TextColor="#757575" />
							<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
								<Entry Text="{Binding EstimatedTime}" Keyboard="Numeric"
                                       BackgroundColor="Transparent" Margin="8,2" FontSize="14" />
							</Border>
						</VerticalStackLayout>
					</Grid>

					<!-- Open Toggle -->
					<Grid ColumnDefinitions="*,Auto">
						<Label Grid.Column="0"
                               Text="{Binding IsOpen, Converter={StaticResource BoolToStringConverter},
                                      ConverterParameter='🟢 المطعم مفتوح|🔴 المطعم مغلق'}"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{Binding IsOpen, Converter={StaticResource BoolToColorConverter}}"
                               VerticalOptions="Center" />
						<Button Grid.Column="1"
                                Text="{Binding IsOpen, Converter={StaticResource BoolToStringConverter},
                                       ConverterParameter='إغلاق المطعم|فتح المطعم'}"
                                Command="{Binding ToggleOpenCommand}"
                                BackgroundColor="{Binding IsOpen, Converter={StaticResource BoolToColorConverter}}"
                                TextColor="White"
                                CornerRadius="10" HeightRequest="40" Padding="12,0" />
					</Grid>

					<!-- Image URLs -->
					<VerticalStackLayout Spacing="4">
						<Label Text="رابط صورة الشعار" FontSize="13" TextColor="#757575" />
						<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
							<Entry Text="{Binding ImageUrl}" BackgroundColor="Transparent"
                                   Margin="8,2" FontSize="12" Keyboard="Url" />
						</Border>
					</VerticalStackLayout>
					<VerticalStackLayout Spacing="4">
						<Label Text="رابط صورة الغلاف" FontSize="13" TextColor="#757575" />
						<Border StrokeShape="RoundRectangle 10" Stroke="#E0E0E0" StrokeThickness="1.5">
							<Entry Text="{Binding CoverUrl}" BackgroundColor="Transparent"
                                   Margin="8,2" FontSize="12" Keyboard="Url" />
						</Border>
					</VerticalStackLayout>

				</VerticalStackLayout>
			</Frame>

			<ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#FF5722" HorizontalOptions="Center" Margin="0,0,0,24" />

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
