<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:RestaurantMaui.Views"
       x:Class="RestaurantMaui.AppShell"
       Shell.NavBarIsVisible="False"
       FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="الرئيسية" Icon="icon_dashboard.png">
            <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" Route="DashboardPage" />
        </Tab>
        <Tab Title="الطلبات" Icon="icon_orders.png">
            <ShellContent ContentTemplate="{DataTemplate views:OrdersPage}" Route="OrdersPage" />
        </Tab>
        <Tab Title="المنيو" Icon="icon_menu.png">
            <ShellContent ContentTemplate="{DataTemplate views:MenuPage}" Route="MenuPage" />
        </Tab>
        <Tab Title="الأقسام" Icon="icon_menu.png">
            <ShellContent ContentTemplate="{DataTemplate views:CategoriesPage}" Route="CategoriesPage" />
        </Tab>
        <Tab Title="الإعدادات" Icon="icon_settings.png">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>
